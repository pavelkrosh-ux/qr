<body>
    <button class="refresh-button" id="refresh-button" title="Обновить"></button>
    <button class="weekend-toggle" id="weekend-toggle" title="Показать/скрыть выходные">Выходные</button>
    
<h1>
        <button class="nav-button" id="prev-week">◀</button>
        Записи с '<span id="period-start">загрузка...</span>' по '<span id="period-end">загрузка...</span>'
        <button class="nav-button" id="next-week">▶</button>
    </h1>
    
   
<div class="table-container">
        
<table id="schedule-table"><thead>
<tr><!-- Заголовки дней будут сгенерированы динамически --></tr></thead>
<tbody><!-- Строки будут сгенерированы динамически (10 строк) --></tbody></table></div>

    
<div class="context-menu" id="contextMenu">
        <button id="addToService">Записать в сервис</button>
        <button id="doNotAdd">Не записывать</button>
        <button id="markDelivered">Привезли</button>
        <button id="openRecord">Открыть запись</button>
        <button id="openChat">Открыть чат</button>
    </div>

    
<script>
        // Глобальные переменные для доступа извне
        var currentData = {
            date: null,
            row: null,
            cellData: {},
            action: null,
            navigation: null
        };
        var columnsCount = 0;
        var currentWeekStart = null;
        var showWeekends = false; // Флаг отображения выходных
        
        // Функция для получения понедельника текущей недели
        function getStartOfWeek(date) {
            var d = new Date(date);
            var day = d.getDay();
            var diff = d.getDate() - day + (day === 0 ? -6 : 1); // adjust when day is Sunday
            return new Date(d.setDate(diff));
        }
        
        // Функция для форматирования даты в YYYY-MM-DD
        function formatDateKey(date) {
            return date.toISOString().split('T')[0];
        }
        
        // Функция для доступа к данным из внешней программы
        window.getItemData = function() {
            return currentData;
        };
        
        // Текущая выбранная ячейка
        var selectedCell = null;
        var selectedDate = null;
        var selectedRow = null;
        var selectedCellData = null;
        
        // Функция для генерации таблицы
        function generateSchedule(data) {
            // Проверяем, что данные в формате JSON
            if (typeof data === 'string') {
                try {
                    data = JSON.parse(data);
                } catch (e) {
                    console.error('Ошибка парсинга JSON:', e);
                    return;
                }
            }
            
            var startDate = new Date(data.periodStart);
            var endDate = new Date(data.periodEnd);
            
            // Сохраняем начало текущей недели для навигации
            currentWeekStart = new Date(startDate);
            
            document.getElementById('period-start').textContent = formatDate(startDate);
            document.getElementById('period-end').textContent = formatDate(endDate);
            
            var table = document.getElementById('schedule-table');
            table.querySelector('thead tr').innerHTML = '';
            table.querySelector('tbody').innerHTML = '';
            
            // Подсчитываем количество дней (колонок)
            var currentDate = new Date(startDate);
            columnsCount = 0;
            while (currentDate <= endDate) {
                columnsCount++;
                currentDate.setDate(currentDate.getDate() + 1);
            }
            
            // Устанавливаем CSS переменную с количеством колонок
            document.documentElement.style.setProperty('--columns-count', columnsCount);
            
            // Генерируем заголовки с датами
            var dateForHeaders = new Date(startDate);
            var thElements = [];
            
            while (dateForHeaders <= endDate) {
                var dayOfWeek = dateForHeaders.getDay();
                var isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
                
                var th = document.createElement('th');
                th.innerHTML = getDayName(dayOfWeek) + '<br>' + formatDate(dateForHeaders);
                if (isWeekend) th.className += ' weekend';
                th.setAttribute('data-date', formatDateKey(dateForHeaders));
                
                // Добавляем класс для фиксации в старых браузерах
                th.className += ' sticky-header';
                
                table.querySelector('thead tr').appendChild(th);
                thElements.push(th);
                
                dateForHeaders.setDate(dateForHeaders.getDate() + 1);
            }
            
            // Генерируем 10 строк
            for (var i = 1; i <= 10; i++) {
                var row = document.createElement('tr');
                
                // Добавляем ячейки для каждого дня
                var currentDate = new Date(startDate);
                var colIndex = 0;
                
                while (currentDate <= endDate) {
                    var dateKey = formatDateKey(currentDate);
                    var dayOfWeek = currentDate.getDay();
                    var isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
                    
                    var td = document.createElement('td');
                    td.className = 'event-cell';
                    if (isWeekend) td.className += ' weekend';
                    td.setAttribute('data-col-index', colIndex);
                    
                    // Обработчики для подсветки заголовка при наведении
                    td.addEventListener('mouseenter', function() {
                        var colIdx = this.getAttribute('data-col-index');
                        thElements[colIdx].className += ' highlighted';
                    });
                    
                    td.addEventListener('mouseleave', function() {
                        var colIdx = this.getAttribute('data-col-index');
                        thElements[colIdx].className = thElements[colIdx].className.replace(' highlighted', '');
                    });
                    
                    // Обработчик клика
                    td.addEventListener('click', function(e) {
                        selectedCell = this;
                        selectedDate = this.parentNode.parentNode.parentNode.querySelector('thead th:nth-child(' + (parseInt(this.getAttribute('data-col-index')) + 1) + ')').getAttribute('data-date');
                        selectedRow = this.parentNode.rowIndex;
                        
                        // Получаем данные ячейки
                        selectedCellData = null;
                        if (data.events[selectedDate] && data.events[selectedDate][selectedRow]) {
                            selectedCellData = data.events[selectedDate][selectedRow];
                        }
                        
                        // Сохраняем данные в глобальную переменную
                        currentData = {
                            date: selectedDate,
                            row: selectedRow,
                            cellData: selectedCellData || {},
                            action: null
                        };
                        
                        showContextMenu(this, e, selectedDate, selectedRow);
                    });
                    
                    // Добавляем данные в ячейку
                    if (data.events && data.events[dateKey] && data.events[dateKey][i]) {
                        var event = data.events[dateKey][i];
                        
                        // Добавляем скрытые данные
                        if (event.Идентификатор) td.setAttribute('data-id', event.Идентификатор);
                        if (event.Подтвердили1) td.setAttribute('data-confirmed1', event.Подтвердили1);
                        if (event.Подтвердили2) td.setAttribute('data-confirmed2', event.Подтвердили2);
                        if (event.Привезли) td.setAttribute('data-delivered', event.Привезли);
                        if (event.Чат) td.setAttribute('data-chat', event.Чат);
                        if (event.НеЗаписывать) td.setAttribute('data-not-scheduled', event.НеЗаписывать);
                        if (event.Время) td.setAttribute('data-time', event.Время);
                        
                        // Определяем приоритет оформления ячейки
                        if (event.НеЗаписывать === true || event.НеЗаписывать === 'Истина') {
                            td.className += ' not-scheduled';
                        } else if (event.Привезли === true || event.Привезли === 'Истина') {
                            td.className += ' delivered';
                        } else if (event.Подтвердили2 === true || event.Подтвердили2 === 'Истина') {
                            td.className += ' confirmed2';
                        } else if (event.Подтвердили1 === true || event.Подтвердили1 === 'Истина') {
                            td.className += ' confirmed1';
                        }
                        
                        // Если НеЗаписывать не равно Истина, добавляем содержимое ячейки
                        if (!(event.НеЗаписывать === true || event.НеЗаписывать === 'Истина')) {
                            // Создаем контейнер для содержимого ячейки
                            var cellContent = document.createElement('div');
                            
                            // Добавляем время вверху ячейки
                            if (event.Время) {
                                var timeDiv = document.createElement('div');
                                timeDiv.className = 'event-time';
                                timeDiv.textContent = event.Время;
                                cellContent.appendChild(timeDiv);
                            }
                            
                            // Создаем блок с основными данными
                            var eventDiv = document.createElement('div');
                            eventDiv.className = 'event-item';
                            
                            // Формируем строку с ТС и пробегом
                            var tsText = event.ТС || '';
                            if (event.Пробег) {
                                tsText += ' (' + event.Пробег + 'км)';
                            }
                            
                            var html = '';
                            if (tsText) html += '<b>ТС:</b> ' + tsText + '<br>';
                            if (event.Клиент) html += '<b>Клиент:</b> ' + event.Клиент + '<br>';
                            if (event.Телефон) html += '<b>Телефон:</b> ' + event.Телефон + '<br>';
                            
                            // Формируем строку с Доставка и Водитель
                            var tsText2 = event.Доставка || '';
                            if (event.Водитель) {
                                tsText2 += ' (' + event.Водитель + ')';
                            }
                            if (tsText2) html += '<b>Доставка:</b> ' + tsText2 + '<br>';
                            
                            if (event.ПричинаОбращения) html += '<b>Причина:</b> ' + event.ПричинаОбращения;
                            
                            eventDiv.innerHTML = html;
                            cellContent.appendChild(eventDiv);
                            td.appendChild(cellContent);
                        }
                    }
                    
                    row.appendChild(td);
                    currentDate.setDate(currentDate.getDate() + 1);
                    colIndex++;
                }
                
                table.querySelector('tbody').appendChild(row);
            }
            
            // Применяем текущее состояние отображения выходных
            toggleWeekends(showWeekends);
        }
        
        // Показать контекстное меню
        function showContextMenu(cell, event, dateKey, rowNum) {
            var contextMenu = document.getElementById('contextMenu');
            var isCellEmpty = selectedCellData === null;
            var hasChat = cell.getAttribute('data-chat') && cell.getAttribute('data-chat') !== '';
            var delivered = cell.getAttribute('data-delivered') === 'true' || cell.getAttribute('data-delivered') === 'Истина';
            var notScheduled = cell.getAttribute('data-not-scheduled') === 'true' || cell.getAttribute('data-not-scheduled') === 'Истина';
            
            if (delivered) {
                // Если Привезли равно Истина, показываем только "Открыть запись"
                document.getElementById('addToService').style.display = 'none';
                document.getElementById('doNotAdd').style.display = 'none';
                document.getElementById('markDelivered').style.display = 'none';
                document.getElementById('openRecord').style.display = 'block';
                document.getElementById('openChat').style.display = hasChat ? 'block' : 'none';
            } else if (notScheduled) {
                // Если НеЗаписывать равно Истина, показываем только "Открыть запись"
                document.getElementById('addToService').style.display = 'none';
                document.getElementById('doNotAdd').style.display = 'none';
                document.getElementById('markDelivered').style.display = 'none';
                document.getElementById('openRecord').style.display = 'block';
                document.getElementById('openChat').style.display = hasChat ? 'block' : 'none';
            } else {
                // Обычное отображение меню
                document.getElementById('addToService').style.display = isCellEmpty ? 'block' : 'none';
                document.getElementById('doNotAdd').style.display = isCellEmpty ? 'block' : 'none';
                document.getElementById('markDelivered').style.display = isCellEmpty ? 'none' : 'block';
                document.getElementById('openRecord').style.display = isCellEmpty ? 'none' : 'block';
                document.getElementById('openChat').style.display = hasChat ? 'block' : 'none';
            }
            
            contextMenu.style.display = 'block';
            
            var menuWidth = contextMenu.offsetWidth;
            var menuHeight = contextMenu.offsetHeight;
            var windowWidth = window.innerWidth;
            var windowHeight = window.innerHeight;
            
            var left = event.clientX;
            var top = event.clientY;
            
            if (left + menuWidth > windowWidth) {
                left = windowWidth - menuWidth - 10;
            }
            
            if (top + menuHeight > windowHeight) {
                top = windowHeight - menuHeight - 10;
            }
            
            contextMenu.style.left = left + 'px';
            contextMenu.style.top = top + 'px';
            
            if (event.preventDefault) {
                event.preventDefault();
                event.stopPropagation();
            } else {
                event.returnValue = false;
                event.cancelBubble = true;
            }
        }
        
        // Закрыть контекстное меню
        function hideContextMenu() {
            document.getElementById('contextMenu').style.display = 'none';
        }
        
        // Обработчик прокрутки таблицы
        function handleTableScroll() {
            hideContextMenu();
        }
        
        // Назначаем обработчик прокрутки для контейнера таблицы
        document.querySelector('.table-container').addEventListener('scroll', handleTableScroll);
        
        // Закрытие контекстного меню при клике вне его
        document.addEventListener('click', function(event) {
            var contextMenu = document.getElementById('contextMenu');
            if (event.target !== contextMenu && !contextMenu.contains(event.target)) {
                hideContextMenu();
            }
        });
        
        // Обновляем currentData при выборе действия
        function updateCurrentData(action) {
            currentData = {
                date: selectedDate,
                row: selectedRow,
                cellData: selectedCellData || {},
                action: action
            };
            return currentData;
        }
        
        // Функция для вызова внешних функций
        function callExternalFunction(functionName, data) {
            console.log('Вызов ' + functionName + ' с данными:', data);
            
            if (window[functionName] && typeof window[functionName] === 'function') {
                window[functionName](data);
            }
        }
        
        // Вспомогательные функции
        function formatDate(date) {
            var day = date.getDate();
            var month = date.getMonth() + 1;
            var year = date.getFullYear();
            
            return (day < 10 ? '0' : '') + day + '.' + (month < 10 ? '0' : '') + month + '.' + year;
        }
        
        function getDayName(dayOfWeek) {
            var days = ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб']; // Сокращенные названия дней
            return days[dayOfWeek];
        }
        
        // Функция для получения дат недели
        function getWeekDates(startDate) {
            var start = new Date(startDate);
            var end = new Date(start);
            end.setDate(end.getDate() + 6);
            
            return {
                periodStart: formatDateKey(start),
                periodEnd: formatDateKey(end)
            };
        }
        
        // Переключение отображения выходных
        function toggleWeekends(show) {
            showWeekends = show;
            var container = document.querySelector('.table-container');
            if (show) {
                container.classList.remove('hide-weekend');
                document.getElementById('weekend-toggle').textContent = 'Скрыть выходные';
            } else {
                container.classList.add('hide-weekend');
                document.getElementById('weekend-toggle').textContent = 'Показать выходные';
            }
        }
        
        // Обработчики для кнопок навигации
        document.getElementById('prev-week').addEventListener('click', function() {
            currentWeekStart.setDate(currentWeekStart.getDate() - 7);
            var week = getWeekDates(currentWeekStart);

            // Обновляем currentData с информацией о навигации
            var navigation = {
                direction: 'prev',
                periodStart: week.periodStart,
                periodEnd: week.periodEnd
            };
            
            currentData = {
                action: 'weekNavigation',
                navigation: navigation || {} 
            };
            
            // Вызываем внешнюю функцию для загрузки данных предыдущей недели
            callExternalFunction('loadWeekData', {
                action: 'weekNavigation',
                direction: 'prev',
                periodStart: week.periodStart,
                periodEnd: week.periodEnd
            });
        });
        
        document.getElementById('next-week').addEventListener('click', function() {
            currentWeekStart.setDate(currentWeekStart.getDate() + 7);
            var week = getWeekDates(currentWeekStart);
                
            // Обновляем currentData с информацией о навигации
            var navigation = {
                direction: 'next',
                periodStart: week.periodStart,
                periodEnd: week.periodEnd
            };
            
            currentData = {
                action: 'weekNavigation',
                navigation: navigation || {} 
            };

            // Вызываем внешнюю функцию для загрузки данных следующей недели
            callExternalFunction('loadWeekData', {
                action: 'weekNavigation',
                direction: 'next',
                periodStart: week.periodStart,
                periodEnd: week.periodEnd
            });
        });
        
        // Обработчик для кнопки обновления
        document.getElementById('refresh-button').addEventListener('click', function() {
            currentData = {
                action: 'update'
            };
            callExternalFunction('updateData', currentData);
        });
        
        // Обработчик для кнопки переключения выходных
        document.getElementById('weekend-toggle').addEventListener('click', function() {
            toggleWeekends(!showWeekends);
        });
        
        // Обработчики для кнопок контекстного меню
        document.getElementById('addToService').addEventListener('click', function() {
            var data = updateCurrentData('ЗаписатьВСервис');
            callExternalFunction('ЗаписатьВСервис', data);
            hideContextMenu();
        });
        
        document.getElementById('doNotAdd').addEventListener('click', function() {
            var data = updateCurrentData('НеЗаписывать');
            callExternalFunction('НеЗаписывать', data);
            hideContextMenu();
        });
        
        document.getElementById('markDelivered').addEventListener('click', function() {
            var data = updateCurrentData('Привезли');
            callExternalFunction('Привезли', data);
            hideContextMenu();
        });
        
        document.getElementById('openRecord').addEventListener('click', function() {
            var data = updateCurrentData('ОткрытьЗапись');
            callExternalFunction('ОткрытьЗапись', data);
            hideContextMenu();
        });
        
        document.getElementById('openChat').addEventListener('click', function() {
            var data = updateCurrentData('ОткрытьЧат');
            callExternalFunction('ОткрытьЧат', data);
            hideContextMenu();
        });
        
        // Функция для инициализации расписания из внешней программы
        window.initializeSchedule = function(data) {
            if (typeof data === 'string') {
                try {
                    data = JSON.parse(data);
                } catch (e) {
                    console.error('Ошибка парсинга JSON:', e);
                    return;
                }
            }
            
            if (data && data.periodStart && data.periodEnd) {
                generateSchedule(data);
            } else {
                // Если данные не переданы, показываем сообщение о загрузке
                document.getElementById('period-start').textContent = 'загрузка...';
                document.getElementById('period-end').textContent = 'загрузка...';
            }
        };
        
        // Функция для обновления данных из внешней программы
        window.updateSchedule = function(data) {
            if (typeof data === 'string') {
                try {
                    data = JSON.parse(data);
                } catch (e) {
                    console.error('Ошибка парсинга JSON:', e);
                    return;
                }
            }
            generateSchedule(data);
        };
        
